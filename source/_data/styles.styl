// ===============================================================
// Mote's Log — 星尘蓝紫配色
// 主色 #9999FF (星尘应援色) + 点缀 #FFFF00
// ===============================================================

// --- Color Variables ---
$stardust = #9999FF
$stardust-light = #b8b8ff
$stardust-dark = #7a7ae0
$stardust-gold = #FFFF00

// --- Links & Accents ---
$link-color = $stardust
$link-color-dark = $stardust-light
$link-hover-color = $stardust-gold
$link-hover-color-dark = $stardust-gold
$btn-default-bg = $stardust
$btn-default-hover-bg = $stardust-dark

// --- Sidebar (Gemini) ---
$sidebar-bg = #1a1a2e
$sidebar-color = #ccd
$sidebar-highlight = $stardust-light

// --- Header / Brand ---
$brand-color = $stardust-light
$brand-hover-color = $stardust-gold
$site-meta-text-color = $stardust-light

// --- Posts ---
$post-meta-color = $stardust-light
$post-title-color = $stardust-light

// --- Code blocks ---
$code-background = #1e1e2e
$code-foreground = #cdd6f4

// --- Scrollbar ---
$scrollbar-color = $stardust

// --- Footer ---
$footer-link-color = $stardust-light

// --- Tags / Categories ---
$tag-cloud-start = $stardust-dark
$tag-cloud-end = $stardust-light

// --- Selection ---
::selection
  background: $stardust
  color: #fff

// --- Menu active ---
.menu-item-active a
  background: $stardust !important
  color: #fff !important

// --- Post title hover ---
.posts-expand .post-title-link:hover
  color: $stardust-gold

// --- Button hover ---
.btn:hover
  background: $stardust-dark
  border-color: $stardust-dark

// --- Back to top ---
.back-to-top
  background: $stardust
  &:hover
    background: $stardust-gold
    color: #1a1a2e

// --- Pagination ---
.pagination .page-number.current
  background: $stardust
